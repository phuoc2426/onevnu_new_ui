	<string>OneVNU sử dụng vị trí của bạn cho Bản đồ số</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>OneVNU sử dụng microphone cho cập nhật ảnh đại diện và thônng tin hồ sơ.</string>
